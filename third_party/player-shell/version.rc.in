      VALUE "InternalName", "minimal-player"
      VALUE "LegalCopyright", "LGPL-2.1-or-later; contains FFmpeg (unmodified, source-vendored)"
      VALUE "OriginalFilename", "minimal-player.exe"
      VALUE "ProductName", "vlc-light-win64 minimal player"
      VALUE "ProductVersion", "@VER_DOT@.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1200
  END
END
